# otp-ninja environment variables template
# Copy this file to .env and fill in your values
# Never commit .env to version control

# Gmail — generate App Password at https://myaccount.google.com/apppasswords
GMAIL_USER=qa-bot@gmail.com
GMAIL_APP_PASSWORD=abcd efgh ijkl mnop

# Outlook / Office 365
OUTLOOK_USER=qa-bot@yourcompany.com
OUTLOOK_APP_PASSWORD=your-app-password

# Twilio SMS — Account SID starts with "AC"
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token

# Vonage SMS
VONAGE_API_KEY=your-vonage-api-key
VONAGE_API_SECRET=your-vonage-api-secret

# TOTP — Base32 shared secret from your authenticator app
TOTP_SECRET=JBSWY3DPEHPK3PXP

# Enable verbose debug logging (credentials are masked in output)
# OTP_NINJA_DEBUG=true
